<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>菜园子 · 阳光正好</title>
<style>
  :root{
    --sky-top:#bfe0f0;
    --sky-bottom:#eaf6e8;
    --soil:#8a6247;
    --soil-dark:#6b4a34;
    --leaf-dark:#3f7a3a;
    --leaf-mid:#5fa14f;
    --leaf-light:#8ecb6b;
    --radish-red:#d9536a;
    --radish-white:#fdf6ee;
    --cabbage:#a8d97a;
    --cabbage-dark:#7cb84f;
    --eggplant:#6a4c8c;
    --eggplant-cap:#4c7a3a;
    --tomato:#e14b3c;
    --tomato-dark:#b73326;
    --cucumber:#4f9e4a;
    --ink:#3f5230;
    --sun:#fff3c4;
  }
  *{box-sizing:border-box;}
  html,body{
    margin:0;
    height:100%;
    overflow:hidden;
    font-family:"Songti SC","STSong","SimSun",serif;
    background:var(--sky-bottom);
  }
  .scene{
    position:relative;
    width:100vw;
    height:100vh;
    background:linear-gradient(to bottom, var(--sky-top) 0%, var(--sky-bottom) 48%);
    overflow:hidden;
  }

  .sun{
    position:absolute;
    top:6%;
    right:14%;
    width:84px;
    height:84px;
    border-radius:50%;
    background:radial-gradient(circle, #fffef2 0%, var(--sun) 55%, rgba(255,243,196,0) 75%);
    box-shadow:0 0 50px 26px rgba(255,243,196,0.5);
    animation:sunpulse 6s ease-in-out infinite;
  }
  @keyframes sunpulse{
    0%,100%{opacity:1;}
    50%{opacity:0.85;}
  }

  .cloud{
    position:absolute;
    background:rgba(255,255,255,0.8);
    border-radius:50px;
    filter:blur(1px);
  }
  .cloud::before, .cloud::after{
    content:"";
    position:absolute;
    background:inherit;
    border-radius:50%;
  }
  .c1{ width:110px; height:28px; top:12%; left:-200px; animation:drift 60s linear infinite; }
  .c1::before{ width:56px; height:46px; top:-22px; left:12px; }
  .c1::after{ width:40px; height:34px; top:-14px; left:58px; }
  .c2{ width:80px; height:20px; top:20%; left:-160px; animation:drift 75s linear infinite; animation-delay:-25s; }
  .c2::before{ width:40px; height:32px; top:-16px; left:8px; }
  @keyframes drift{
    from{ transform:translateX(0); }
    to{ transform:translateX(calc(100vw + 260px)); }
  }

  .butterfly{
    position:absolute;
    font-size:16px;
    animation:flutter 8s ease-in-out infinite;
  }
  .bf1{ top:34%; left:20%; animation-delay:0s; }
  .bf2{ top:38%; left:65%; animation-delay:2s; }
  @keyframes flutter{
    0%,100%{ transform:translate(0,0) rotate(0deg); }
    25%{ transform:translate(20px,-14px) rotate(10deg); }
    50%{ transform:translate(40px,4px) rotate(-6deg); }
    75%{ transform:translate(16px,-8px) rotate(8deg); }
  }

  .poem{
    position:absolute;
    top:5%;
    left:6%;
    color:var(--ink);
    opacity:0.7;
    font-size:14px;
    line-height:2;
    letter-spacing:2px;
    writing-mode:vertical-rl;
    z-index:6;
  }

  /* Soil bed */
  .soil{
    position:absolute;
    bottom:0;
    left:0;
    width:100%;
    height:38%;
    background:linear-gradient(to bottom, var(--soil) 0%, var(--soil-dark) 100%);
    z-index:1;
  }
  .furrow{
    position:absolute;
    left:0;
    width:100%;
    height:3px;
    background:rgba(0,0,0,0.12);
  }

  /* Fence along the back of the garden */
  .fence{
    position:absolute;
    bottom:38%;
    left:0;
    width:100%;
    height:15%;
    z-index:2;
    display:flex;
    align-items:flex-end;
  }
  .picket{
    position:relative;
    width:14px;
    height:100%;
    margin:0 4px;
    background:linear-gradient(to bottom, #d9b088 0%, #b8895f 100%);
    border-radius:6px 6px 2px 2px;
    box-shadow:inset -2px 0 0 rgba(0,0,0,0.08);
    flex:0 0 auto;
  }
  .picket::before{
    content:"";
    position:absolute;
    top:-8px;
    left:0;
    width:0;
    height:0;
    border-left:7px solid transparent;
    border-right:7px solid transparent;
    border-bottom:10px solid #c99a6c;
  }
  .rail{
    position:absolute;
    left:0;
    width:100%;
    height:8px;
    background:#a97c52;
    opacity:0.85;
    border-radius:2px;
  }
  .rail.top{ bottom:60%; }
  .rail.bottom{ bottom:15%; }

  .plot{
    position:absolute;
    bottom:0;
    width:20%;
    height:100%;
    display:flex;
    justify-content:center;
    align-items:flex-end;
    z-index:2;
  }

  .sway{
    animation:sway 2.6s ease-in-out infinite;
    transform-origin:bottom center;
  }
  @keyframes sway{
    0%,100%{ transform:rotate(-3deg); }
    50%{ transform:rotate(4deg); }
  }

  .radish-leaf{
    position:relative;
    width:46px;
    height:34px;
  }
  .radish-leaf .leaf{
    position:absolute;
    bottom:0;
    width:14px;
    height:30px;
    background:var(--leaf-mid);
    border-radius:50% 50% 10px 10px;
  }
  .radish-leaf .leaf:nth-child(1){ left:2px; transform:rotate(-18deg); background:var(--leaf-dark); }
  .radish-leaf .leaf:nth-child(2){ left:16px; height:34px; }
  .radish-leaf .leaf:nth-child(3){ left:28px; transform:rotate(18deg); background:var(--leaf-light); }
  .radish-bulb{
    position:absolute;
    bottom:-8px;
    left:16px;
    width:16px;
    height:20px;
    background:linear-gradient(to bottom, var(--radish-red) 0%, var(--radish-red) 60%, var(--radish-white) 60%, var(--radish-white) 100%);
    border-radius:0 0 8px 8px / 0 0 10px 10px;
  }

  .cabbage-plant{
    position:relative;
    width:52px;
    height:44px;
  }
  .cabbage-plant .leafball{
    position:absolute;
    bottom:0;
    left:2px;
    width:48px;
    height:40px;
    background:radial-gradient(circle at 50% 40%, var(--cabbage) 0%, var(--cabbage-dark) 90%);
    border-radius:50%;
  }
  .cabbage-plant .leafball::before, .cabbage-plant .leafball::after{
    content:"";
    position:absolute;
    width:22px;
    height:22px;
    background:var(--cabbage);
    border-radius:50%;
    opacity:0.8;
  }
  .cabbage-plant .leafball::before{ top:-4px; left:-6px; }
  .cabbage-plant .leafball::after{ top:-4px; right:-6px; }

  .eggplant-plant{
    position:relative;
    width:44px;
    height:56px;
  }
  .eggplant-plant .stem{
    position:absolute;
    bottom:0;
    left:20px;
    width:5px;
    height:40px;
    background:var(--leaf-dark);
    border-radius:3px;
  }
  .eggplant-plant .leaf{
    position:absolute;
    width:22px;
    height:16px;
    background:var(--leaf-mid);
    border-radius:50% 50% 50% 0;
  }
  .eggplant-plant .leaf.l1{ bottom:26px; left:2px; transform:rotate(-25deg); }
  .eggplant-plant .leaf.l2{ bottom:14px; left:20px; transform:rotate(20deg) scaleX(-1); }
  .eggplant-plant .fruit{
    position:absolute;
    bottom:0;
    left:10px;
    width:20px;
    height:30px;
    background:linear-gradient(160deg, var(--eggplant) 0%, #8a6cad 60%, var(--eggplant) 100%);
    border-radius:50% 50% 60% 60% / 60% 60% 70% 70%;
  }
  .eggplant-plant .cap{
    position:absolute;
    bottom:26px;
    left:12px;
    width:16px;
    height:8px;
    background:var(--eggplant-cap);
    border-radius:4px 4px 0 0;
  }

  .tomato-plant{
    position:relative;
    width:46px;
    height:58px;
  }
  .tomato-plant .stem{
    position:absolute;
    bottom:0;
    left:21px;
    width:5px;
    height:44px;
    background:var(--leaf-dark);
    border-radius:3px;
  }
  .tomato-plant .leaf{
    position:absolute;
    width:20px;
    height:14px;
    background:var(--leaf-mid);
    border-radius:0 50% 0 50%;
  }
  .tomato-plant .leaf.l1{ bottom:32px; left:0; transform:rotate(-20deg); }
  .tomato-plant .leaf.l2{ bottom:18px; left:24px; transform:rotate(15deg) scaleX(-1); }
  .tomato-plant .cluster{
    position:absolute;
    bottom:20px;
    left:14px;
  }
  .tomato-plant .fruit{
    position:absolute;
    width:14px;
    height:14px;
    border-radius:50%;
    background:radial-gradient(circle at 35% 30%, #ff7a63 0%, var(--tomato) 60%, var(--tomato-dark) 100%);
  }
  .tomato-plant .fruit.f1{ left:0; top:0; }
  .tomato-plant .fruit.f2{ left:14px; top:8px; }
  .tomato-plant .fruit.f3{ left:2px; top:16px; }

  .cucumber-plant{
    position:relative;
    width:44px;
    height:70px;
  }
  .cucumber-plant .vine{
    position:absolute;
    bottom:0;
    left:20px;
    width:4px;
    height:60px;
    background:var(--leaf-dark);
    border-radius:2px;
  }
  .cucumber-plant .leaf{
    position:absolute;
    width:22px;
    height:18px;
    background:var(--leaf-light);
    border-radius:50% 0 50% 50%;
  }
  .cucumber-plant .leaf.l1{ bottom:44px; left:-2px; transform:rotate(-15deg); }
  .cucumber-plant .leaf.l2{ bottom:30px; left:22px; transform:rotate(15deg) scaleX(-1); }
  .cucumber-plant .leaf.l3{ bottom:16px; left:-4px; transform:rotate(-10deg); }
  .cucumber-plant .fruit{
    position:absolute;
    bottom:6px;
    left:16px;
    width:10px;
    height:36px;
    background:linear-gradient(90deg, var(--leaf-dark) 0%, var(--cucumber) 30%, var(--cucumber) 70%, var(--leaf-dark) 100%);
    border-radius:6px;
  }

  .caption{
    position:absolute;
    bottom:3%;
    left:50%;
    transform:translateX(-50%);
    color:#f4f9ee;
    font-size:14px;
    opacity:0.9;
    letter-spacing:3px;
    text-align:center;
    white-space:nowrap;
    z-index:10;
    text-shadow:0 1px 3px rgba(0,0,0,0.3);
  }
</style>
</head>
<body>
<div class="scene" id="scene">

  <div class="sun"></div>
  <div class="cloud c1"></div>
  <div class="cloud c2"></div>
  <div class="butterfly bf1">🦋</div>
  <div class="butterfly bf2">🦋</div>

  <div class="poem">菜园子里 · 四季常青</div>

  <div class="fence" id="fence">
    <div class="rail top"></div>
    <div class="rail bottom"></div>
  </div>

  <div class="soil" id="soil"></div>

  <div class="caption">萝卜白菜 · 茄子西红柿黄瓜</div>
</div>

<script>
  const soil = document.getElementById('soil');
  const fence = document.getElementById('fence');

  const picketCount = 26;
  for(let i=0;i<picketCount;i++){
    const picket = document.createElement('div');
    picket.className = 'picket';
    fence.appendChild(picket);
  }

  for(let i=0;i<4;i++){
    const f = document.createElement('div');
    f.className = 'furrow';
    f.style.bottom = (10 + i*22) + '%';
    soil.appendChild(f);
  }

  const plots = [
    { name:'radish', count:3 },
    { name:'cabbage', count:2 },
    { name:'eggplant', count:2 },
    { name:'tomato', count:2 },
    { name:'cucumber', count:2 },
  ];

  function buildRadish(){
    const wrap = document.createElement('div');
    wrap.className = 'sway';
    wrap.innerHTML = `
      <div class="radish-leaf">
        <div class="leaf"></div>
        <div class="leaf"></div>
        <div class="leaf"></div>
        <div class="radish-bulb"></div>
      </div>`;
    return wrap;
  }
  function buildCabbage(){
    const wrap = document.createElement('div');
    wrap.className = 'sway';
    wrap.innerHTML = `
      <div class="cabbage-plant">
        <div class="leafball"></div>
      
