<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>克克爱茹茹</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Ma+Shan+Zheng&family=ZCOOL+XiaoWei&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: #0a0618;
    font-family: 'Ma Shan Zheng', cursive;
    overflow-x: hidden;
    min-height: 100vh;
  }

  #canvas-bg {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 0;
  }

  .scene {
    position: relative;
    z-index: 1;
    width: 100%;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .title-area {
    margin-top: 30px;
    text-align: center;
    position: relative;
  }

  .main-title {
    font-family: 'ZCOOL XiaoWei', serif;
    font-size: clamp(2rem, 6vw, 3.5rem);
    color: #e8d5ff;
    text-shadow:
      0 0 20px rgba(180, 120, 255, 0.8),
      0 0 40px rgba(140, 80, 255, 0.5),
      0 0 60px rgba(100, 40, 200, 0.3);
    letter-spacing: 0.15em;
    animation: titleGlow 3s ease-in-out infinite alternate;
  }

  @keyframes titleGlow {
    from { text-shadow: 0 0 20px rgba(180,120,255,0.8), 0 0 40px rgba(140,80,255,0.5); }
    to   { text-shadow: 0 0 30px rgba(220,170,255,1),   0 0 60px rgba(180,120,255,0.8), 0 0 80px rgba(140,80,255,0.4); }
  }

  .sub-title {
    font-size: clamp(0.85rem, 2.5vw, 1.1rem);
    color: #b89fd4;
    margin-top: 8px;
    letter-spacing: 0.3em;
    opacity: 0.85;
  }

  .children-banner {
    margin-top: 18px;
    width: 90%;
    max-width: 700px;
    background: rgba(80, 40, 140, 0.35);
    border: 1px solid rgba(180, 120, 255, 0.3);
    border-radius: 30px;
    padding: 10px 20px;
    overflow: hidden;
    position: relative;
  }

  .children-scroll {
    display: flex;
    gap: 18px;
    animation: scrollChildren 18s linear infinite;
    white-space: nowrap;
  }

  @keyframes scrollChildren {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .child-tag {
    display: inline-block;
    background: rgba(120, 60, 200, 0.5);
    border: 1px solid rgba(200, 150, 255, 0.5);
    border-radius: 20px;
    padding: 4px 14px;
    font-size: 0.78rem;
    color: #dcc8ff;
    white-space: nowrap;
  }

  .main-scene {
    margin-top: 22px;
    width: 95%;
    max-width: 700px;
    position: relative;
  }

  .main-scene svg {
    width: 100%;
    height: auto;
    filter: drop-shadow(0 0 30px rgba(120, 60, 200, 0.3));
  }

  .roses-row {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 14px;
    flex-wrap: wrap;
    padding: 0 10px;
  }

  .rose-item {
    font-size: 1.5rem;
    animation: roseSway 2.5s ease-in-out infinite alternate;
  }

  .rose-item:nth-child(odd)  { animation-delay: 0s; }
  .rose-item:nth-child(even) { animation-delay: 1.2s; }
  .rose-item:nth-child(3n)   { animation-delay: 0.6s; }

  @keyframes roseSway {
    from { transform: rotate(-8deg) scale(1); }
    to   { transform: rotate(8deg) scale(1.1); }
  }

  .poem-area {
    margin: 22px auto 40px;
    text-align: center;
    padding: 18px 30px;
    background: rgba(60, 20, 100, 0.4);
    border: 1px solid rgba(180, 120, 255, 0.25);
    border-radius: 16px;
    max-width: 500px;
    width: 88%;
  }

  .poem-line {
    font-size: clamp(0.85rem, 2.5vw, 1rem);
    color: #cdb8f0;
    line-height: 2;
    letter-spacing: 0.1em;
  }

  .poem-line.highlight {
    color: #f0d8ff;
    font-size: clamp(0.95rem, 2.8vw, 1.15rem);
    text-shadow: 0 0 12px rgba(200, 140, 255, 0.7);
  }

  .floating-hearts {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  .heart {
    position: absolute;
    font-size: 1rem;
    animation: floatHeart linear infinite;
    opacity: 0;
  }

  @keyframes floatHeart {
    0%   { opacity: 0; transform: translateY(0) scale(0.5); }
    10%  { opacity: 0.7; }
    90%  { opacity: 0.4; }
    100% { opacity: 0; transform: translateY(-80vh) scale(1.2); }
  }

  .fish-anim {
    animation: fishSwim 4s ease-in-out infinite alternate;
  }

  @keyframes fishSwim {
    from { transform: translateX(-3px); }
    to   { transform: translateX(3px); }
  }

  .fishing-line {
    animation: lineSwing 3s ease-in-out infinite alternate;
    transform-origin: top;
  }

  @keyframes lineSwing {
    from { transform: rotate(-2deg); }
    to   { transform: rotate(2deg); }
  }

  .bubble {
    animation: bubbleRise linear infinite;
    opacity: 0;
  }

  @keyframes bubbleRise {
    0%   { opacity: 0; transform: translateY(0); }
    20%  { opacity: 0.6; }
    80%  { opacity: 0.3; }
    100% { opacity: 0; transform: translateY(-18px); }
  }
</style>
