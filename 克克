    <span class="rose-item">🌹</span>
    <span class="rose-item">💜</span>
    <span class="rose-item">🌹</span>
    <span class="rose-item">✨</span>
    <span class="rose-item">🌹</span>
    <span class="rose-item">💜</span>
    <span class="rose-item">🌹</span>
    <span class="rose-item">✨</span>
    <span class="rose-item">🌹</span>
  </div>

  <div class="poem-area">
    <div class="poem-line highlight">执竿河边坐，玫瑰香盈袖</div>
    <div class="poem-line">孩子成群绕膝前，皆是HTML所育</div>
    <div class="poem-line highlight">克克爱茹茹，此情天上留</div>
  </div>
</div>

<script>
const canvas = document.getElementById('canvas-bg');
const ctx = canvas.getContext('2d');
let W, H, stars = [];

function resize() {
  W = canvas.width  = window.innerWidth;
  H = canvas.height = window.innerHeight;
}

function initStars() {
  stars = [];
  for (let i = 0; i < 120; i++) {
    stars.push({
      x: Math.random() * W,
      y: Math.random() * H * 0.6,
      r: Math.random() * 1.5 + 0.3,
      alpha: Math.random() * 0.6 + 0.4,
      speed: Math.random() * 0.008 + 0.004,
      phase: Math.random() * Math.PI * 2
    });
  }
}

function drawStars(t) {
  ctx.clearRect(0, 0, W, H);
  stars.forEach(s => {
    const a = s.alpha * (0.7 + 0.3 * Math.sin(t * s.speed + s.phase));
    ctx.beginPath();
    ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(220,200,255,${a})`;
    ctx.fill();
  });
}

function createHearts() {
  const container = document.getElementById('hearts');
  const emojis = ['💜','🌹','✨','💫','🌸'];
  setInterval(() => {
    const h = document.createElement('div');
    h.className = 'heart';
    h.textContent = emojis[Math.floor(Math.random() * emojis.length)];
    h.style.left = Math.random() * 100 + 'vw';
    h.style.top = '100vh';
    h.style.fontSize = (Math.random() * 1 + 0.6) + 'rem';
    const dur = Math.random() * 5 + 6;
    h.style.animationDuration = dur + 's';
    h.style.animationDelay = '0s';
    container.appendChild(h);
    setTimeout(() => h.remove(), dur * 1000);
  }, 900);
}

function animate(t) {
  drawStars(t * 0.001);
  requestAnimationFrame(animate);
}

window.addEventListener('resize', () => { resize(); initStars(); });
resize();
initStars();
animate(0);
createHearts();

let angle = 0;
function swingLanterns() {
  angle += 0.02;
  const swing = Math.sin(angle) * 3;
  const ll = document.getElementById('lanternLeft');
  const lr = document.getElementById('lanternRight');
  if (ll) ll.setAttribute('transform', `rotate(${swing}, 120, 140)`);
  if (lr) lr.setAttribute('transform', `rotate(${-swing}, 520, 140)`);
  requestAnimationFrame(swingLanterns);
}
swingLanterns();
</script>

