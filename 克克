        <text x="120" y="175" text-anchor="middle" font-size="8" fill="#ffd0a0">福</text>
        <line x1="120" y1="182" x2="118" y2="192" stroke="#ff8080" stroke-width="1"/>
        <line x1="120" y1="182" x2="122" y2="192" stroke="#ff8080" stroke-width="1"/>
      </g>
      <g id="lanternRight">
        <line x1="520" y1="140" x2="520" y2="160" stroke="#8060a0" stroke-width="1.5"/>
        <rect x="512" y="160" width="16" height="22" rx="8" fill="#8040c0" opacity="0.85"/>
        <rect x="512" y="160" width="16" height="22" rx="8" fill="url(#lanternGlow)" opacity="0.4"/>
        <line x1="512" y1="160" x2="528" y2="160" stroke="#c080ff" stroke-width="1"/>
        <line x1="512" y1="182" x2="528" y2="182" stroke="#c080ff" stroke-width="1"/>
        <text x="520" y="175" text-anchor="middle" font-size="8" fill="#e0c0ff">爱</text>
        <line x1="520" y1="182" x2="518" y2="192" stroke="#c080ff" stroke-width="1"/>
        <line x1="520" y1="182" x2="522" y2="192" stroke="#c080ff" stroke-width="1"/>
