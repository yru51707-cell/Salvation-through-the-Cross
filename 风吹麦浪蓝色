<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>麦穗 · 晴日</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body {
    width: 100%; height: 100%;
    overflow: hidden;
    background: #cdeeff;
    font-family: 'Noto Serif SC', 'STSong', serif;
    touch-action: manipulation;
  }
  #scene {
    position: relative;
    width: 100%; height: 100%;
    background: linear-gradient(180deg,
      #4fa8e0 0%,
      #6fc0ee 25%,
      #9adcf5 50%,
      #c9edf7 75%,
      #eef9f2 100%);
    cursor: pointer;
    overflow: hidden;
  }

  #sun {
    position: absolute;
    top: 9%;
    right: 16%;
    width: 78px;
    height: 78px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, #fffef2, #ffe9a0 55%, #ffd15c 100%);
    box-shadow: 0 0 50px 18px rgba(255, 226, 140, 0.55);
  }

  .cloud {
    position: absolute;
    background: #ffffff;
    border-radius: 50px;
    opacity: 0.9;
    animation: floatCloud linear infinite;
  }
  @keyframes floatCloud {
    from { transform: translateX(-120px); }
    to { transform: translateX(calc(100vw + 120px)); }
  }

  #hills {
    position: absolute;
    bottom: 32%;
    width: 100%;
    height: 16%;
    background: #7fae6a;
    clip-path: polygon(0% 100%, 0% 45%, 15% 60%, 30% 35%, 48% 55%, 65% 25%, 82% 50%, 100% 30%, 100% 100%);
    opacity: 0.7;
  }

  #field {
    position: absolute;
    bottom: 0;
    width: 100%;
    height: 40%;
    background: linear-gradient(180deg, #8a6a3a 0%, #5c4526 100%);
    overflow: hidden;
  }

  .stalk {
    position: absolute;
    bottom: 0;
    transform-origin: bottom center;
    animation: sway var(--dur) ease-in-out infinite;
    animation-delay: var(--delay);
  }
  .stalk svg { display: block; width: 100%; height: 100%; }

  @keyframes sway {
    0%, 100% { transform: rotate(var(--rot1)); }
    50% { transform: rotate(var(--rot2)); }
  }

  .gust .stalk {
    animation: gust 1.1s ease-out;
  }
  @keyframes gust {
    0% { transform: rotate(0deg); }
    25% { transform: rotate(22deg); }
    55% { transform: rotate(-10deg); }
    80% { transform: rotate(6deg); }
    100% { transform: rotate(0deg); }
  }

  .bird {
    position: absolute;
    font-size: 14px;
    color: #3a5a6c;
    animation: flyAcross linear infinite;
    opacity: 0.7;
  }
  @keyframes flyAcross {
    from { transform: translateX(-40px) translateY(0); }
    to { transform: translateX(calc(100vw + 40px)) translateY(-20px); }
  }

  #poem {
    position: absolute;
    top: 10%;
    left: 8%;
    color: #2b4a3a;
    text-shadow: 0 2px 10px rgba(255,255,255,0.6);
    line-height: 1.9;
    font-size: 17px;
    letter-spacing: 2px;
    opacity: 0;
    animation: fadeIn 2s ease forwards 0.6s;
    z-index: 5;
  }
  #poem .line { display: block; }
  #poem .title {
    font-size: 15px;
    opacity: 0.6;
    margin-bottom: 10px;
    letter-spacing: 3px;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  #hint {
    position: absolute;
    bottom: 4%;
    width: 100%;
    text-align: center;
    color: rgba(43, 74, 58, 0.55);
    font-size: 12px;
    letter-spacing: 3px;
    z-index: 5;
    animation: fadeIn 2s ease forwards 1.8s;
    opacity: 0;
  }
</style>
</head>
<body>

<div id="scene">
  <div id="sun"></div>
  <div id="hills"></div>
  <div id="poem">
    <span class="title">· 麦 熟 ·</span>
    <span class="line">晴空万里映麦黄,</span>
    <span class="line">风吹浪起满田香。</span>
    <span class="line">燕子低飞衔新讯,</span>
    <span class="line">丰年将至好时光。</span>
  </div>
  <div id="field"></div>
  <div id="hint">轻触田野 · 起风</div>
</div>

<script>
const scene = document.getElementById('scene');
const field = document.getElementById('field');

function makeCloud(top, scale, duration, delay) {
  const c = document.createElement('div');
  c.className = 'cloud';
  const w = 90 * scale, h = 28 * scale;
  c.style.width = w + 'px';
  c.style.height = h + 'px';
  c.style.top = top + '%';
  c.style.left = '0';
  c.style.animationDuration = duration + 's';
  c.style.animationDelay = delay + 's';
  scene.appendChild(c);
  const b1 = document.createElement('div');
  b1.style.position = 'absolute';
  b1.style.background = '#ffffff';
  b1.style.borderRadius = '50%';
  b1.style.width = (w*0.55) + 'px';
  b1.style.height = (w*0.55) + 'px';
  b1.style.top = -(w*0.25) + 'px';
  b1.style.left = (w*0.12) + 'px';
  c.appendChild(b1);
  const b2 = document.createElement('div');
  b2.style.position = 'absolute';
  b2.style.background = '#ffffff';
  b2.style.borderRadius = '50%';
  b2.style.width = (w*0.4) + 'px';
  b2.style.height = (w*0.4) + 'px';
  b2.style.top = -(w*0.15) + 'px';
  b2.style.left = (w*0.5) + 'px';
  c.appendChild(b2);
}
makeCloud(12, 1, 55, 0);
makeCloud(20, 0.7, 70, -20);
makeCloud(8, 1.3, 65, -40);
makeCloud(26, 0.6, 48, -10);

for (let i = 0; i < 5; i++) {
  const b = document.createElement('div');
  b.className = 'bird';
  b.textContent = '⌒';
  b.style.top = (15 + Math.random() * 20) + '%';
  b.style.animationDuration = (14 + Math.random() * 10) + 's';
  b.style.animationDelay = (Math.random() * -15) + 's';
  scene.appendChild(b);
}

const stalkCount = 90;
const wheatSVG = (hue) => `
<svg viewBox="0 0 20 140" xmlns="http://www.w3.org/2000/svg">
  <line x1="10" y1="140" x2="10" y2="20" stroke="${hue.stem}" stroke-width="2.2"/>
  <g fill="${hue.head}">
    <ellipse cx="10" cy="10" rx="4" ry="9"/>
    <ellipse cx="5" cy="18" rx="3.2" ry="7" transform="rotate(-25 5 18)"/>
    <ellipse cx="15" cy="18" rx="3.2" ry="7" transform="rotate(25 15 18)"/>
    <ellipse cx="4" cy="30" rx="2.8" ry="6" transform="rotate(-35 4 30)"/>
    <ellipse cx="16" cy="30" rx="2.8" ry="6" transform="rotate(35 16 30)"/>
  </g>
</svg>`;

const goldTones = [
  { stem: '#8a6a2f', head: '#f0cf4a' },
  { stem: '#7a5d29', head: '#e8bf3e' },
  { stem: '#93732f', head: '#f7dc6a' },
  { stem: '#6f5424', head: '#d9a934' }
];

for (let i = 0; i < stalkCount; i++) {
  const stalk = document.createElement('div');
  stalk.className = 'stalk';
  const heightPx = 90 + Math.random() * 60;
  const widthPx = heightPx * (20/140);
  stalk.style.width = widthPx + 'px';
  stalk.style.height = heightPx + 'px';
  stalk.style.left = (Math.random() * 100) + '%';
  stalk.style.zIndex = Math.floor(heightPx);
  const rot1 = (Math.random() * 4 - 2).toFixed(1);
  const rot2 = (parseFloat(rot1) + (Math.random() * 6 + 3)).toFixed(1);
  stalk.style.setProperty('--rot1', rot1 + 'deg');
  stalk.style.setProperty('--rot2', rot2 + 'deg');
  stalk.style.setProperty('--dur', (2.5 + Math.random() * 2) + 's');
  stalk.style.setProperty('--delay', (Math.random() * -3) + 's');
  const tone = goldTones[Math.floor(Math.random() * goldTones.length)];
  stalk.innerHTML = wheatSVG(tone);
  field.appendChild(stalk);
}

let gustCooldown = false;
scene.addEventListener('click', () => {
  if (gustCooldown) return;
  gustCooldown = true;
  field.classList.remove('gust');
  void field.offsetWidth;
  field.classList.add('gust');
  setTimeout(() => { gustCooldown = false; }, 900);
});
</script>

</body>
</html>
