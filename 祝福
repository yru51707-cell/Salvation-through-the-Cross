<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>心灵抽签 · 夜空祝福</title>
<style>
  :root{
    --sky-deep:#0d0a2b;
    --sky-mid:#231a4d;
    --sky-glow:#3d2e7c;
    --gold:#f4d580;
    --gold-deep:#c9992f;
    --card-back:#2a2060;
    --card-edge:#6b57c9;
    --ink:#3a2e12;
    --text-soft:#d9d3f0;
  }
  *{box-sizing:border-box;}
  html,body{
    margin:0;
    height:100%;
    overflow:hidden;
    font-family:"Songti SC","STSong","SimSun",serif;
    background:var(--sky-deep);
  }
  .scene{
    position:relative;
    width:100vw;
    height:100vh;
    background:radial-gradient(ellipse at 50% 20%, var(--sky-glow) 0%, var(--sky-mid) 45%, var(--sky-deep) 100%);
    overflow:hidden;
    display:flex;
    flex-direction:column;
    align-items:center;
  }

  .star{
    position:absolute;
    background:#fff;
    border-radius:50%;
    animation:twinkle ease-in-out infinite;
  }
  @keyframes twinkle{
    0%,100%{ opacity:0.2; }
    50%{ opacity:1; }
  }

  .title{
    position:relative;
    z-index:5;
    text-align:center;
    color:var(--gold);
    margin-top:9%;
    letter-spacing:6px;
    font-size:22px;
    text-shadow:0 0 12px rgba(244,213,128,0.5);
  }
  .subtitle{
    position:relative;
    z-index:5;
    text-align:center;
    color:var(--text-soft);
    opacity:0.75;
    font-size:13px;
    margin-top:8px;
    letter-spacing:2px;
  }

  .card-wrap{
    position:relative;
    z-index:5;
    margin-top:9%;
    width:64vw;
    max-width:260px;
    height:44vh;
    max-height:340px;
    perspective:1200px;
  }
  .card{
    position:relative;
    width:100%;
    height:100%;
    transform-style:preserve-3d;
    transition:transform 0.8s cubic-bezier(.2,.8,.3,1);
    cursor:pointer;
  }
  .card.flipped{
    transform:rotateY(180deg);
  }
  .card-face{
    position:absolute;
    width:100%;
    height:100%;
    border-radius:18px;
    backface-visibility:hidden;
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    padding:20px;
    text-align:center;
  }
  .card-back{
    background:linear-gradient(160deg, var(--card-back) 0%, #1b1440 100%);
    border:2px solid var(--card-edge);
    box-shadow:0 0 30px rgba(107,87,201,0.5), inset 0 0 40px rgba(107,87,201,0.25);
  }
  .card-back .glyph{
    font-size:44px;
    color:var(--gold);
    opacity:0.85;
    text-shadow:0 0 16px rgba(244,213,128,0.6);
  }
  .card-back .hint{
    margin-top:14px;
    color:var(--text-soft);
    opacity:0.6;
    font-size:13px;
    letter-spacing:2px;
  }
  .card-front{
    background:linear-gradient(160deg, #fdf6e3 0%, #f7e9c2 100%);
    border:2px solid var(--gold-deep);
    box-shadow:0 0 34px rgba(244,213,128,0.55);
    transform:rotateY(180deg);
  }
  .card-front .verse{
    color:var(--ink);
    font-size:16px;
    line-height:1.9;
    letter-spacing:1px;
  }
  .card-front .verse-mark{
    margin-top:16px;
    color:var(--gold-deep);
    font-size:12px;
    opacity:0.8;
    letter-spacing:2px;
  }

  .redraw{
    position:relative;
    z-index:5;
    margin-top:8%;
    padding:10px 28px;
    background:transparent;
    border:1px solid rgba(244,213,128,0.5);
    color:var(--gold);
    border-radius:24px;
    font-size:14px;
    letter-spacing:3px;
    opacity:0;
    pointer-events:none;
    transition:opacity 0.5s ease 0.4s;
  }
  .redraw.show{
    opacity:0.9;
    pointer-events:auto;
  }

  .sparkle-burst{
    position:absolute;
    width:6px;
    height:6px;
    border-radius:50%;
    background:var(--gold);
    pointer-events:none;
    opacity:0;
    z-index:6;
  }
  @keyframes burstout{
    0%{ transform:translate(0,0) scale(1); opacity:1; }
    100%{ transform:translate(var(--dx), var(--dy)) scale(0); opacity:0; }
  }
</style>
</head>
<body>
<div class="scene" id="scene">

  <div class="title">心灵抽签</div>
  <div class="subtitle">轻触卡牌 · 领一句祝福</div>

  <div class="card-wrap">
    <div class="card" id="card">
      <div class="card-face card-back">
        <div class="glyph">✦</div>
        <div class="hint">轻触翻开</div>
      </div>
      <div class="card-face card-front">
        <div class="verse" id="verseText"></div>
        <div class="verse-mark">· 愿这句话安你的心 ·</div>
      </div>
    </div>
  </div>

  <div class="redraw" id="redrawBtn">再抽一张</div>
</div>

<script>
  const scene = document.getElementById('scene');
  const card = document.getElementById('card');
  const verseText = document.getElementById('verseText');
  const redrawBtn = document.getElementById('redrawBtn');

  for(let i=0;i<70;i++){
    const s = document.createElement('div');
    s.className = 'star';
    const size = Math.random()*2 + 1;
    s.style.width = size + 'px';
    s.style.height = size + 'px';
    s.style.left = Math.random()*100 + '%';
    s.style.top = Math.random()*70 + '%';
    s.style.animationDuration = (2 + Math.random()*3) + 's';
    s.style.animationDelay = (Math.random()*3) + 's';
    scene.appendChild(s);
  }

  const verses = [
    '一天的难处一天当就够了，今天的路，今天走。',
    '你所走的每一段旷野，都不是被遗忘的路。',
    '安静下来，让心先停靠一会儿，答案不急于今天。',
    '软弱的时候，恰是能安静倚靠的时候。',
    '今天的重担，明天自有新的力量来担。',
    '你不是一个人在扛，有一份看顾一直都在。',
    '风浪会过去，此刻的摇晃不是永远的光景。',
    '小小的感恩，也能松开心里那根绷紧的弦。',
    '慢慢来，扎根本就不是一天的事。',
    '你现在的忍耐，将来会开出你意想不到的花。',
    '不必事事都懂，有些平安是先来到心里的。',
    '今天，允许自己歇一歇，这也是一种前行。',
    '黑夜再长，也有天亮的时候。',
    '你所忍受的，将来都不会是白白流失的。',
    '心里的重担，可以放下来，喘一口气。'
  ];

  let usedIndexes = [];

  function pickVerse(){
    if(usedIndexes.length >= verses.length){ usedIndexes = []; }
    let idx;
    do{
      idx = Math.floor(Math.random()*verses.length);
    } while(usedIndexes.includes(idx));
    usedIndexes.push(idx);
    return verses[idx];
  }

  function burstSparkles(){
    const rect = card.getBoundingClientRect();
    const cx = rect.left + rect.width/2;
    const cy = rect.top + rect.height/2;
    for(let i=0;i<24;i++){
      const p = document.createElement('div');
      p.className = 'sparkle-burst';
      const angle = Math.random()*Math.PI*2;
      const dist = 60 + Math.random()*90;
      const dx = Math.cos(angle)*dist;
      const dy = Math.sin(angle)*dist;
      p.style.left = cx + 'px';
      p.style.top = cy + 'px';
      p.style.setProperty('--dx', dx + 'px');
      p.style.setProperty('--dy', dy + 'px');
      p.style.animation = 'burstout 0.9s ease-out forwards';
      p.style.animationDelay = (Math.random()*0.15) + 's';
      scene.appendChild(p);
      setTimeout(()=>p.remove(), 1200);
    }
  }

  let flipped = false;
  card.addEventListener('click', () => {
    if(!flipped){
      verseText.textContent = pickVerse();
      card.classList.add('flipped');
      flipped = true;
      setTimeout(burstSparkles, 420);
      redrawBtn.classList.add('show');
    }
  });

  redrawBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    card.classList.remove('flipped');
    redrawBtn.classList.remove('show');
    flipped = false;
  });
</script>
</body>
</html>
