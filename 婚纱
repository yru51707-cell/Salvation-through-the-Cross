<style>
  @import url('https://fonts.googleapis.com/css2?family=Ma+Shan+Zheng&family=ZCOOL+XiaoWei&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: #1a0828;
    font-family: 'Ma Shan Zheng', cursive;
    overflow-x: hidden;
    min-height: 100vh;
  }

  #canvas-bg {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 0;
  }

  .scene {
    position: relative;
    z-index: 1;
    width: 100%;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-bottom: 50px;
  }

  .xi-banner {
    margin-top: 28px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .xi-char {
    font-family: 'ZCOOL XiaoWei', serif;
    font-size: clamp(3rem, 10vw, 5rem);
    color: #ff2020;
    text-shadow:
      0 0 15px rgba(255,60,60,0.9),
      0 0 30px rgba(255,40,40,0.6),
      2px 2px 0 #aa0000;
    animation: xiPulse 2s ease-in-out infinite alternate;
  }

  @keyframes xiPulse {
    from { transform: scale(1);    text-shadow: 0 0 15px rgba(255,60,60,0.9), 2px 2px 0 #aa0000; }
    to   { transform: scale(1.08); text-shadow: 0 0 28px rgba(255,80,80,1), 0 0 50px rgba(255,40,40,0.5), 2px 2px 0 #aa0000; }
  }

  .title-center { text-align: center; }

  .main-title {
    font-family: 'ZCOOL XiaoWei', serif;
    font-size: clamp(1.4rem, 4.5vw, 2.2rem);
    color: #ffd0f0;
    text-shadow: 0 0 18px rgba(255,140,200,0.8);
    letter-spacing: 0.2em;
    animation: titleGlow 3s ease-in-out infinite alternate;
  }

  @keyframes titleGlow {
    from { text-shadow: 0 0 18px rgba(255,140,200,0.8); }
    to   { text-shadow: 0 0 30px rgba(255,180,220,1), 0 0 55px rgba(240,120,180,0.6); }
  }

  .sub-title {
    font-size: clamp(0.8rem, 2.2vw, 1rem);
    color: #e0a0cc;
    margin-top: 6px;
    letter-spacing: 0.3em;
    opacity: 0.85;
  }

  .main-scene {
    margin-top: 20px;
    width: 95%;
    max-width: 680px;
  }

  .main-scene svg {
    width: 100%;
    height: auto;
    filter: drop-shadow(0 0 25px rgba(255,100,180,0.25));
  }

  .petals-row {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 16px;
    flex-wrap: wrap;
  }

  .petal {
    font-size: 1.4rem;
    animation: petalSway 2s ease-in-out infinite alternate;
  }
  .petal:nth-child(odd)  { animation-delay: 0s; }
  .petal:nth-child(even) { animation-delay: 1s; }
  .petal:nth-child(3n)   { animation-delay: 0.5s; }

  @keyframes petalSway {
    from { transform: rotate(-10deg) scale(1); }
    to   { transform: rotate(10deg) scale(1.15); }
  }

  .vow-area {
    margin: 20px auto 20px;
    text-align: center;
    padding: 20px 28px;
    background: rgba(180, 40, 100, 0.15);
    border: 1px solid rgba(255, 150, 200, 0.35);
    border-radius: 20px;
    max-width: 500px;
    width: 88%;
    position: relative;
  }

  .vow-area::before, .vow-area::after {
    content: '❧';
    position: absolute;
    font-size: 1.4rem;
    color: #ff80c0;
    opacity: 0.6;
  }
  .vow-area::before { top: 10px; left: 14px; }
  .vow-area::after  { bottom: 10px; right: 14px; transform: rotate(180deg); }

  .vow-line {
    font-size: clamp(0.88rem, 2.5vw, 1.05rem);
    color: #f0c0e0;
    line-height: 2.1;
    letter-spacing: 0.12em;
  }

  .vow-line.big {
    font-size: clamp(1rem, 3vw, 1.25rem);
    color: #ffd8ee;
    text-shadow: 0 0 10px rgba(255,140,200,0.6);
  }

  .floating-petals {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  .fall-petal {
    position: absolute;
    animation: fallDown linear infinite;
    opacity: 0;
  }

  @keyframes fallDown {
    0%   { opacity: 0; transform: translateY(-20px) rotate(0deg); }
    10%  { opacity: 0.8; }
    90%  { opacity: 0.5; }
    100% { opacity: 0; transform: translateY(105vh) rotate(360deg); }
  }

  .ring-anim {
    animation: ringShine 3s ease-in-out infinite alternate;
  }
  @keyframes ringShine {
    from { opacity: 0.85; }
    to   { opacity: 1; filter: brightness(1.3); }
  }
</style>
