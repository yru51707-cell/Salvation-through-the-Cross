<script>
const canvas = document.getElementById('canvas-bg');
const ctx = canvas.getContext('2d');
let W, H, stars = [];

function resize() {
  W = canvas.width  = window.innerWidth;
  H = canvas.height = window.innerHeight;
}

function initStars() {
  stars = [];
  for (let i = 0; i < 100; i++) {
    stars.push({
      x: Math.random() * W,
      y: Math.random() * H * 0.5,
      r: Math.random() * 1.3 + 0.3,
      alpha: Math.random() * 0.5 + 0.3,
      speed: Math.random() * 0.007 + 0.003,
      phase: Math.random() * Math.PI * 2
    });
  }
}

function drawStars(t) {
  ctx.clearRect(0, 0, W, H);
  stars.forEach(s => {
    const a = s.alpha * (0.7 + 0.3 * Math.sin(t * s.speed + s.phase));
    ctx.beginPath();
    ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(255,200,230,${a})`;
    ctx.fill();
  });
}

function animate(t) {
  drawStars(t * 0.001);
  requestAnimationFrame(animate);
}

window.addEventListener('resize', () => { resize(); initStars(); });
resize(); initStars(); animate(0);

function createPetals() {
  const container = document.getElementById('petals');
  const emojis = ['🌸','💗','🌺','✨','💜','🌷','💕'];
  setInterval(() => {
    const p = document.createElement('div');
    p.className = 'fall-petal';
    p.textContent = emojis[Math.floor(Math.random() * emojis.length)];
    p.style.left = Math.random() * 100 + 'vw';
    p.style.top = '-30px';
    p.style.fontSize = (Math.random() * 0.8 + 0.7) + 'rem';
    const dur = Math.random() * 5 + 7;
    p.style.animationDuration = dur + 's';
    container.appendChild(p);
    setTimeout(() => p.remove(), dur * 1000 + 500);
  }, 700);
}
createPetals();

let bAngle = 0;
function animBalloons() {
  bAngle += 0.018;
  const sway  = Math.sin(bAngle) * 4;
  const sway2 = Math.sin(bAngle + 1) * 3;
  const dy    = Math.sin(bAngle * 0.7) * 5;
  const bl  = document.getElementById('balloonL');
  const br  = document.getElementById('balloonR');
  const bl2 = document.getElementById('balloonL2');
  const br2 = document.getElementById('balloonR2');
  if (bl)  bl.setAttribute('transform',  `translate(${sway},${dy})`);
  if (br)  br.setAttribute('transform',  `translate(${-sway},${dy})`);
  if (bl2) bl2.setAttribute('transform', `translate(${sway2},${-dy})`);
  if (br2) br2.setAttribute('transform', `translate(${-sway2},${-dy})`);
  requestAnimationFrame(animBalloons);
}
animBalloons();
</script>
